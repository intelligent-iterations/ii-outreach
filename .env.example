# Outreach repo environment variables

# xAI / Grok
XAI_API_KEY=xai-xxxxx

# Reddit API (read-only context via PRAW)
REDDIT_CLIENT_ID=xxxxx
REDDIT_CLIENT_SECRET=xxxxx
REDDIT_USER_AGENT=outreach-bot/1.0 by /u/your_username

# Optional local overrides
# REDDIT_USERNAME=your_username
# REDDIT_PASSWORD=your_password
# REDDIT_COOKIES_PATH=data/cookies_your_username.json

# X credentials are configured in x-outreach/.env
