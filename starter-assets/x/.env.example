# ===========================================
# X Outreach Bot - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values

# ===========================================
# OPTIONAL: Override config.json credentials
# ===========================================
# If set, these override the accounts in config.json
# Useful for CI/CD or when you don't want passwords in config files
X_USERNAME=your_username
X_PASSWORD=your_password
X_COOKIES_PATH=auth/cookies_your_username.json
